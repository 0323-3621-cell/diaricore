# Copy to Railway → web service → Variables (or local .env). Never commit real secrets.

# Required in production — random string (32+ chars). Signs session cookies.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Admin: register/login with this exact email to open /admin after sign-in.
DIARI_ADMIN_EMAIL=you@example.com

# Optional: disable Content-Security-Policy if something breaks (debug only).
# DIARI_DISABLE_CSP=1

# Optional: server-side voice (Hugging Face). Browsers use on-device Whisper by default.
# HF_TOKEN=
# HF_SPEECH_MODEL=openai/whisper-large-v3

# Email (Brevo) — can also be set in Admin panel after login.
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=
# BREVO_SENDER_NAME=DiariCore
